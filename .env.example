# Yandex OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REFRESH_TOKEN=
# Optional: scopes to request in OAuth (used by `mcp-yandex-ad auth`)
# Example: direct:api metrika:read metrika:write
YANDEX_SCOPES=
# Redirect URI used in your app settings (used by `mcp-yandex-ad auth`)
YANDEX_REDIRECT_URI=https://oauth.yandex.ru/verification_code
# Optional loopback redirect (for hybrid local callback in CLI auth):
# YANDEX_REDIRECT_URI=http://127.0.0.1:8765/callback
# Optional direct token (if you are not using refresh flow)
# YANDEX_ACCESS_TOKEN=

# Wordstat via Yandex Search API
YANDEX_SEARCH_API_FOLDER_ID=
YANDEX_SEARCH_API_API_KEY=
# Optional: IAM token instead of API key
# YANDEX_SEARCH_API_IAM_TOKEN=
# Optional: override for testing/proxying
# YANDEX_SEARCH_API_WORDSTAT_BASE_URL=

# Audience OAuth (optional overrides; by default uses main Yandex OAuth)
YANDEX_AUDIENCE_CLIENT_ID=
YANDEX_AUDIENCE_CLIENT_SECRET=
YANDEX_AUDIENCE_REFRESH_TOKEN=
# Optional: scopes/redirect for Audience auth tools (otherwise falls back to main YANDEX_* vars)
YANDEX_AUDIENCE_SCOPES=
YANDEX_AUDIENCE_REDIRECT_URI=
# Optional: direct token (if you are not using refresh flow)
# YANDEX_AUDIENCE_ACCESS_TOKEN=

# Direct API
YANDEX_DIRECT_CLIENT_LOGIN=
# Optional: list of Direct client logins to show as choices in MCP tool schemas.
# Example: YANDEX_DIRECT_CLIENT_LOGINS=elama-11111111,elama-22222222
YANDEX_DIRECT_CLIENT_LOGINS=
YANDEX_DIRECT_SANDBOX=false
# Direct API version (v5 or v501)
YANDEX_DIRECT_API_VERSION=v501
# Write guardrails
MCP_WRITE_ENABLED=false
MCP_WRITE_SANDBOX_ONLY=true
# PRO safety (optional): require explicit confirm for writes
MCP_TWO_PHASE_WRITES=false
MCP_CONFIRM_TTL_SECONDS=300

# Pro-only: enable OAuth helper tools (returns secrets; no storage)
MCP_AUTH_TOOLS_ENABLED=false

# Accounts registry (multi-project profiles; non-secret JSON file)
MCP_ACCOUNTS_FILE=
# Allow accounts.* write operations (upsert/delete). Default false.
MCP_ACCOUNTS_WRITE_ENABLED=false

# Human-friendly (HF) tools layer
HF_ENABLED=true
HF_WRITE_ENABLED=false
# Enables destructive HF tools (delete). Default false.
HF_DESTRUCTIVE_ENABLED=false

# Runtime safety (optional)
# MCP responses: json | summary | summary_json
MCP_CONTENT_MODE=json
# Session cache: only for stable endpoints (Direct dictionaries, Metrica counters)
MCP_CACHE_ENABLED=true
MCP_CACHE_TTL_SECONDS=300
# Rate limiting (0 = disabled)
MCP_DIRECT_RATE_LIMIT_RPS=0
MCP_METRICA_RATE_LIMIT_RPS=0
MCP_AUDIENCE_RATE_LIMIT_RPS=0
MCP_WORDSTAT_RATE_LIMIT_RPS=10
# Retries on transient errors (timeouts, 429, 5xx, quota)
MCP_RETRY_MAX_ATTEMPTS=3
MCP_RETRY_BASE_DELAY_SECONDS=0.5
MCP_RETRY_MAX_DELAY_SECONDS=8

# Metrica
YANDEX_METRICA_COUNTER_IDS=

# Wordstat
MCP_WORDSTAT_ENABLED=true

# Audience
MCP_AUDIENCE_ENABLED=true
